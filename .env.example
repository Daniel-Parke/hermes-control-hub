# Optional Control Hub server tuning (copy to .env.local for Next.js)

# PORT=3000



# Hermes data directory (must match the Hermes agent)

# HERMES_HOME=/home/you/.hermes



# Control Hub JSON data root (missions, templates, operations, stories).

# Default: $HOME/control-hub/data (matches nested Hermes cron mission updates).

# CH_DATA_DIR=/home/you/control-hub/data

# (alias) CONTROL_HUB_DATA_DIR=



# Comma-separated extra dev origins for next.config (e.g. http://192.168.1.10:3000)

# CH_ALLOWED_DEV_ORIGINS=



# Require API key for mutating routes (cron, missions, config, agent files, operations)

# CH_API_KEY=



# Block all writes (GET still works)

# CH_READ_ONLY=1



# Force-disable POST /api/update even in development

# CH_ENABLE_DEPLOY_API=false



# Git branch for deploy/update API and scripts/update.sh (default main)

# CH_UPDATE_GIT_BRANCH=dev



# Edition: simple (OSS default) or commercial (full UI + template library).

# Put these in .env.local — typing `CH_EDITION=simple` in the shell without `export` does not apply to `npm run build` or `npm run dev`.

# NEXT_PUBLIC_CH_EDITION is fixed when you run `next build` or start dev (from .env.local).

# CH_EDITION=simple

# NEXT_PUBLIC_CH_EDITION=simple

